flowchart LR
  classDef coleta fill:#dbe7f3,stroke:#2c5f8a,color:#11314d;
  classDef model  fill:#fde3cc,stroke:#c8702a,color:#5a330f;
  classDef detec  fill:#e7f0d9,stroke:#5a8a2c,color:#2d4a12;
  classDef rito   fill:#f6dcdc,stroke:#b03030,color:#5a1212;
  classDef saida  fill:#ece5f6,stroke:#6a4ca0,color:#33215c;

  subgraph S1["1 · COLETA E DEFINIÇÃO DO ESCOPO"]
    direction TB
    A1["<b>Coleta de dados (JSON) do PNCP</b><br/><i>API pública oficial · Lei 14.133/2021</i>"]:::coleta
    A2["<b>Estatística descritiva</b><br/><i>modalidade, tipo, esfera, região</i>"]:::coleta
    A3["<b>Filtragem inicial</b><br/><i>período, esfera, órgãos, modalidade,<br/>categoria do item · rótulos: engenharia,<br/>obras, serviços gerais (cat. 8)</i>"]:::coleta
    A1 --> A2 --> A3
  end

  subgraph S2["2 · MODELAGEM PU (Positive-Unlabeled)"]
    direction TB
    B0["<b>Rotulagem PU</b><br/><i>positivos confiáveis = engenharia + obras<br/>ruidoso = serviços gerais · base ~93% 'geral'<br/>(só o positivo é confiável)</i>"]:::model
    B1["<b>Pré-tratamento + limpeza de boilerplate</b><br/><i>remove prefixos burocráticos p/ não<br/>inflar a similaridade</i>"]:::model
    B2["<b>Embeddings semânticos SBERT</b><br/><i>distiluse-base-multilingual · normalização L2</i>"]:::model
    B3["<b>Filtro por similaridade ao centróide eng+obras</b><br/><i>separa candidatos × negativos confiáveis</i>"]:::model
    B4["<b>Clusterização auto-k (KMeans)</b><br/><i>k 6–12 pelo melhor silhouette (cosseno)<br/>descritores TF-IDF + stemmer RSLP</i>"]:::model
    B5["<b>Revisão de clusters assistida por LLM</b>"]:::model
    B6["<b>Treino de classificadores supervisionados</b><br/><i>LogReg, RF, ExtraTrees, GB, SVM, kNN, MLP, NB<br/>melhor modelo por F1 macro (holdout)</i>"]:::model
    B0 --> B1 --> B2 --> B3 --> B4 --> B5 --> B6
  end

  subgraph S3["3 · DETECÇÃO DE SUBENQUADRAMENTO"]
    direction TB
    C1["<b>Pontua TODOS os 'serviços gerais'</b><br/><i>predict_proba → prob. de ser engenharia</i>"]:::detec
    C2["<b>Ranking de suspeitos + corte por limiar</b><br/><i>limiar vindo da validação (máx. F1), não fixo</i>"]:::detec
    C3["<b>Validação manual (~80 contratos, estratificada)</b><br/><i>precisão / recall / F1 honestos</i>"]:::detec
    C4["<b>Veredito LLM nos suspeitos do topo</b><br/><i>cruzamento ML × LLM reduz falso positivo</i>"]:::detec
    C5["<b>Visualização: UMAP 2D + rede k-NN + curva de limiar</b><br/><i>suspeitos colados aos eng confirmados</i>"]:::detec
    C1 --> C2 --> C3 --> C4 --> C5
  end

  subgraph S4["4 · ANÁLISE DE RITO (evidência definitiva)"]
    direction TB
    D1["<b>Baixa documentos dos suspeitos</b><br/><i>resolve contrato → compra (numeroControlePNCP)<br/>endpoint /compras/{ano}/{seq}/arquivos<br/>TR / Projeto Básico / Edital</i>"]:::rito
    D2["<b>Detecta marcadores legais no TR</b><br/><i>CREA/ART, projeto básico, ABNT, Lei 14.133/2021<br/>extração PyMuPDF + regex · SEM CAU/RRT</i>"]:::rito
    D3["<b>Veredito por contrato</b><br/><i>subenquadramento real × rótulo errado, processo ok<br/>× indeterminado · base: Lei 5.194/66 + CONFEA</i>"]:::rito
    D1 --> D2 --> D3
  end

  OUT["<b>Artefatos gerados</b><br/>modelo_final.joblib · 07_ranking_suspeitos.csv · 08_validacao.csv<br/>11_analise_rito.csv · figuras (clusters, UMAP, grafo k-NN, curva de limiar)<br/>relatorio_vivo.md"]:::saida

  S1 --> S2 --> S3 --> S4 --> OUT
